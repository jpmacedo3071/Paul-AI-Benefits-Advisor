/* global React */
function TrustStrip() {
  return (
    <section style={trustStyles.wrap}>
      <TrustItem
        icon={
          <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" strokeWidth="1.75" strokeLinecap="round" strokeLinejoin="round">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z"/>
            <path d="m9 12 2 2 4-4"/>
          </svg>
        }
        title="Private &amp; confidential"
        body="We don't collect your name, and nothing you ask is shared with your employer."
      />
      <TrustItem
        icon={
          <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" strokeWidth="1.75" strokeLinecap="round" strokeLinejoin="round">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8Z"/>
            <path d="M14 2v6h6"/>
            <path d="M8 13h8M8 17h5"/>
          </svg>
        }
        title="Plain-English answers"
        body="No jargon. Ask the way you'd ask a friend. Paul explains as much, or as little, as you want."
      />
      <TrustItem
        icon={
          <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" strokeWidth="1.75" strokeLinecap="round" strokeLinejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <polyline points="12 6 12 12 16 14"/>
          </svg>
        }
        title="Here when you need him"
        body="Open enrollment, a new prescription, or planning future treatment, Paul is available any hour."
      />
    </section>
  );
}

function TrustItem({ icon, title, body }) {
  return (
    <div style={trustStyles.item}>
      <div style={trustStyles.iconWrap}>{icon}</div>
      <div>
        <div style={trustStyles.title} dangerouslySetInnerHTML={{ __html: title }} />
        <div style={trustStyles.body}>{body}</div>
      </div>
    </div>
  );
}

const trustStyles = {
  wrap: {
    maxWidth: 1120,
    margin: "28px auto 40px",
    padding: "24px",
    background: "var(--brand-blue-tint)",
    borderRadius: 20,
    display: "grid",
    gridTemplateColumns: "repeat(3, 1fr)",
    gap: 28,
  },
  item: {
    display: "flex",
    alignItems: "flex-start",
    gap: 14,
  },
  iconWrap: {
    flexShrink: 0,
    width: 40,
    height: 40,
    borderRadius: 12,
    background: "#fff",
    color: "var(--brand-blue)",
    display: "inline-flex",
    alignItems: "center",
    justifyContent: "center",
  },
  title: {
    fontFamily: "var(--font-sans)",
    fontSize: 15,
    fontWeight: 600,
    color: "var(--navy-900)",
    marginBottom: 4,
  },
  body: {
    fontFamily: "var(--font-sans)",
    fontSize: 13.5,
    lineHeight: 1.55,
    color: "var(--fg-2)",
  },
};

window.TrustStrip = TrustStrip;
